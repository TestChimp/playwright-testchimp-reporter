{
  "name": "@testchimp/playwright",
  "version": "0.1.9",
  "description": "Playwright reporter for TestChimp test execution tracking and coverage reporting",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.mjs",
      "require": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc && cp esm/runtime-entry.mjs dist/runtime.mjs",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test test/*.test.js"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.0",
    "cheerio": "^1.0.0",
    "axios": "^1.6.0",
    "dotenv": "^17.0.0",
    "ai-wright": "^0.0.12",
    "form-data": "^4.0.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "testchimp",
    "playwright",
    "reporter",
    "test-automation",
    "coverage"
  ],
  "author": "TestChimp",
  "license": "MIT"
}
